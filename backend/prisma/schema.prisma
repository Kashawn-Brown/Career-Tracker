generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  
  isActive      Boolean @default(true)

  // Authorization role (source of truth for admin access)
  role          UserRole @default(USER)
  // Entitlement plan (source of truth for feature/AI access)
  plan          UserPlan @default(REGULAR)

  // Profile fields
  location     String?
  currentCompany  String?
  currentRole  String?
  skills       String[] @default([])
  linkedInUrl  String?
  githubUrl    String?
  portfolioUrl String?

  // Job search preferences
  jobSearchTitlesText    String?
  jobSearchLocationsText String?
  jobSearchKeywordsText  String?
  jobSearchSummary       String?
  jobSearchWorkMode      WorkMode @default(UNKNOWN)

  // One base resume per user
  baseResumeUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastActiveAt DateTime?
  emailVerifiedAt DateTime?

  jobApplications JobApplication[]
  connections    Connection[]
  documents       Document[]
  aiArtifacts          AiArtifact[]
  userAiArtifacts      UserAiArtifact[]
  productEvents        ProductEvent[]
  aiRuns               AiRun[]
  artifactInteractions ArtifactInteraction[]
  planUsageCycles      PlanUsageCycle[]
  planUsageAdjustments PlanUsageAdjustment[]
  planRequests         PlanRequest[]

  authSessions    AuthSession[]

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  aiProRequests AiProRequest[]

  oauthAccounts OAuthAccount[]


  @@index([role])
  @@index([plan])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  REGULAR
  PRO
  PRO_PLUS
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String

  // Store only hashes (never raw tokens)
  refreshTokenHash String   @unique
  csrfTokenHash    String

  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

enum OAuthProvider {
  GOOGLE
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}


model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique

  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique

  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

enum AiProRequestStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  CREDITS_GRANTED
}

model AiProRequest {
  id           String @id @default(cuid())
  userId       String

  note         String?

  status       AiProRequestStatus @default(PENDING)

  requestedAt  DateTime @default(now())
  decidedAt    DateTime?

  decisionNote String?

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, requestedAt])
  @@map("ai_pro_requests")
}



model JobApplication {
  id          String @id @default(cuid())
  userId      String
  company     String
  position    String
  status      ApplicationStatus @default(APPLIED)
  dateApplied DateTime?

  location    String?
  locationDetails   String?

  jobType JobType @default(UNKNOWN)
  jobTypeDetails String?

  workMode   WorkMode @default(UNKNOWN)
  workModeDetails String?
  
  salaryText String?
  salaryDetails  String?
  
  isFavorite Boolean  @default(false)

  jobLink      String?
  description  String?
  notes        String?
  tagsText     String?
  jdSummary    String?

  fitScore     Int?

  connections    ApplicationConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fitUpdatedAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  aiArtifacts          AiArtifact[]
  productEvents        ProductEvent[]
  aiRuns               AiRun[]
  artifactInteractions ArtifactInteraction[]

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum JobType {
  UNKNOWN
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkMode {
  UNKNOWN
  REMOTE
  HYBRID
  ONSITE
}


model Document {
  id               Int          @id @default(autoincrement())
  userId           String
  jobApplicationId String?

  kind         DocumentKind
  storageKey   String
  originalName String
  mimeType     String
  size         Int?
  url          String? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobApplicationId])
  @@map("documents")
}

enum DocumentKind {
  BASE_RESUME
  RESUME

  BASE_COVER_LETTER
  COVER_LETTER

  OTHER
  CAREER_HISTORY
}


model Connection {
  id            String   @id @default(cuid())
  userId        String

  name          String
  company       String?
  title         String?
  email         String?
  linkedInUrl   String?
  notes         String?

  phone         String?       // Add a type for phone (assuming String; adjust as needed)
  relationship  String?       // (e.g., recruiter, referrer, colleague)
  location      String?
  status        Boolean?      // (active, inactive, etc.)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  ApplicationConnection[]

  @@index([userId])
  @@map("connections")
}

model ApplicationConnection {
  jobApplicationId String
  connectionId     String
  createdAt        DateTime @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  connection     Connection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@id([jobApplicationId, connectionId])
  @@index([connectionId])
  @@map("application_connections")
}

model AiArtifact {
  id               String @id @default(cuid())
  userId           String
  jobApplicationId String

  kind    String
  payload Json
  model   String

  sourceDocumentId Int?

  createdAt DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobApplicationId])
  @@index([jobApplicationId, kind])
  @@map("ai_artifacts")
}

/**
 * User-scoped AI artifact — for generic tools (resume advice, cover letter)
 * that are not tied to a specific job application.
 *
 * resumeSource: "BASE_RESUME" | "UPLOAD"
 * sourceDocumentId: Document.id of the uploaded resume (null for base resume runs)
 *
 * Capped at MAX_USER_ARTIFACTS_PER_KIND (3) per user per kind.
 * Oldest is auto-deleted when the cap is exceeded.
 */
model UserAiArtifact {
  id               String   @id @default(cuid())
  userId           String

  kind             String   // "RESUME_ADVICE" | "COVER_LETTER"
  payload          Json
  model            String

  // Which resume was used for this run
  resumeSource     String   // "BASE_RESUME" | "UPLOAD"
  sourceDocumentId Int?     // Document.id if an uploaded resume was used

  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, kind])
  @@index([userId, kind, createdAt])
  @@map("user_ai_artifacts")
}


// ─── Analytics ────────────────────────────────────────────────────────────────

/**
 * ProductEvent — lean tracking of major product actions.
 *
 * Only used for meaningful user/system events (application created, export
 * performed, etc.). Not a clickstream. Metadata holds small contextual details
 * specific to the event type.
 */
model ProductEvent {
  id            String   @id @default(cuid())
  userId        String?
  applicationId String?

  eventType  String  // e.g. "APPLICATION_CREATED", "JD_EXTRACTION_SUCCEEDED"
  category   String  // "APPLICATION" | "AI" | "ARTIFACT" | "EXPORT" | "AUTH" | "ADMIN"
  surface    String? // e.g. "DRAWER" | "TOOLS_PAGE" | "CREATE_FORM"

  // Snapshot plan/role at event time — users may change plan later
  planAtTime String?
  roleAtTime String?

  metadata Json? // small contextual details; never the primary model

  createdAt DateTime @default(now())

  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([applicationId, createdAt(sort: Desc)])
  @@map("product_events")
}

/**
 * AiRun — first-class ledger record for every meaningful AI invocation.
 *
 * This is the most important analytics table. It records every AI tool run
 * with timing, token usage, cost estimates, and success/failure details so
 * we can answer: which tools are expensive, which fail most, which users
 * consume the most AI, and which plans drive the most usage.
 */
model AiRun {
  id            String  @id @default(cuid())
  userId        String
  applicationId String?

  // Links back to the artifact created by this run (set on success)
  userArtifactId        String? // UserAiArtifact.id for generic tool runs
  applicationArtifactId String? // AiArtifact.id for targeted tool runs

  // What ran and where
  toolKind      String  // "JD_EXTRACTION" | "FIT" | "RESUME_HELP" | "COVER_LETTER_HELP" | "RESUME_ADVICE" | "COVER_LETTER" | "INTERVIEW_PREP"
  scope         String  // "GENERIC" | "TARGETED"
  triggerSource String  // "TOOLS_PAGE" | "APPLICATION_DRAWER" | "CREATE_FLOW" | "SYSTEM"

  // Provider / model
  provider String?
  model    String?

  // Lifecycle
  status        String   // "STARTED" | "SUCCEEDED" | "FAILED"
  errorCode     String?
  errorMessage  String?
  errorCategory String?  // "AUTH" | "VALIDATION" | "MODEL_PROVIDER" | "TIMEOUT" | "RATE_LIMIT" | "PARSING" | "PERSISTENCE" | "UNKNOWN"

  startedAt   DateTime
  completedAt DateTime?
  durationMs  Int?

  // Input/output sizing
  inputChars  Int?
  outputChars Int?

  // Token usage (populated when the provider returns it)
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?

  // Estimated cost in USD as a decimal string (null when not calculable)
  estimatedCostUsd String?

  // Context at time of run
  resumeMode String? // "NONE" | "BASE" | "ATTACHED" | "UPLOADED_OVERRIDE"
  jdMode     String? // "NONE" | "PASTED" | "LINK" | "APPLICATION_DESCRIPTION"

  // Snapshot plan/role — users may change plan; we need historical truth
  planAtTime String?
  roleAtTime String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([toolKind, createdAt(sort: Desc)])
  @@index([scope, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([planAtTime, createdAt(sort: Desc)])
  @@index([applicationId, createdAt(sort: Desc)])
  @@index([provider, model, createdAt(sort: Desc)])
  @@map("ai_runs")
}

/**
 * ArtifactInteraction — tracks whether generated outputs are actually used.
 *
 * Generating an artifact and it being valuable are two different things.
 * This table lets us see whether users return to, copy, or regenerate
 * their AI outputs — answering "did this tool actually help?"
 */
model ArtifactInteraction {
  id            String  @id @default(cuid())
  userId        String
  applicationId String?

  // Exactly one of these should be set per interaction
  userArtifactId        String? // UserAiArtifact.id for generic artifacts
  applicationArtifactId String? // AiArtifact.id for targeted artifacts

  interactionType String // "VIEWED" | "COPIED" | "REGENERATED"
  artifactKind    String // e.g. "RESUME_ADVICE", "INTERVIEW_PREP", "FIT_V1"
  scope           String // "GENERIC" | "TARGETED"

  metadata Json?

  createdAt DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([interactionType, createdAt(sort: Desc)])
  @@index([artifactKind, createdAt(sort: Desc)])
  @@index([applicationId, createdAt(sort: Desc)])
  @@map("artifact_interactions")
}


// ─── Plan entitlements ────────────────────────────────────────────

/**
 * PlanUsageCycle — one record per user per calendar month.
 *
 * Tracks how many credits have been consumed in the current cycle and what
 * the effective allowance is. A new row is created (or upserted) at the start
 * of each month. Manual adjustments (credits added by admin) are recorded
 * separately in PlanUsageAdjustment and reflected in bonusCredits here.
 */
model PlanUsageCycle {
  id        String   @id @default(cuid())
  userId    String

  // Cycle boundaries (UTC, start of month)
  cycleYear  Int   // e.g. 2026
  cycleMonth Int   // 1–12

  // Base allowance for this cycle (snapshot from plan at cycle start)
  baseCredits  Int @default(0)
  // Admin-added bonus credits for this cycle
  bonusCredits Int @default(0)
  // Credits consumed by successful AI runs this cycle
  usedCredits  Int @default(0)

  // Plan that was active when this cycle was created
  planAtCycleStart String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One cycle row per user per month
  @@unique([userId, cycleYear, cycleMonth])
  @@index([userId, cycleYear, cycleMonth])
  @@map("plan_usage_cycles")
}

/**
 * PlanUsageAdjustment — audit trail for manual credit changes.
 *
 * Every time an admin adds credits, resets a user, or promotes them to PRO,
 * a row is written here. This keeps the cycle row clean while preserving a
 * full history of admin actions for accountability.
 */
model PlanUsageAdjustment {
  id     String @id @default(cuid())
  userId String

  // Which cycle this adjustment applies to
  cycleYear  Int
  cycleMonth Int

  adjustmentType String  // "ADD_CREDITS" | "RESET_CYCLE" | "PLAN_PROMOTION"
  creditsAdded   Int     @default(0) // positive = credits added
  note           String? // optional admin note

  // Who performed the adjustment
  adminUserId String?

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, cycleYear, cycleMonth])
  @@index([adminUserId])
  @@map("plan_usage_adjustments")
}

/**
 * PlanRequest — user-initiated requests for more credits or plan upgrade.
 *
 * Replaces the old AiProRequest model conceptually, but coexists with it
 * during the transition. Covers both credit requests and PRO upgrade requests
 * in one model with a requestType discriminator.
 */
model PlanRequest {
  id     String @id @default(cuid())
  userId String

  // "MORE_CREDITS" | "UPGRADE_PRO"
  requestType String

  // Snapshot of plan at request time
  planAtRequest String

  status String @default("PENDING") // "PENDING" | "APPROVED" | "DECLINED"

  // User-provided context (optional)
  userNote String?

  // Admin response
  adminNote   String?
  adminUserId String?
  decidedAt   DateTime?

  requestedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, requestedAt(sort: Desc)])
  @@map("plan_requests")
}
